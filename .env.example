# Server
PORT=3000
NODE_ENV=development

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# STT provider: elevenlabs | openai | local | auto
# - elevenlabs: always use ElevenLabs Scribe v2 (recommended)
# - openai: always use OpenAI Whisper API
# - local: always use the local Python hybrid engine (requires models; deprecated in cloud deployment)
# - auto: cloud-first. ElevenLabs if ELEVENLABS_API_KEY is set, otherwise OpenAI/Groq, otherwise local engine
TILTAB_STT_PROVIDER=auto

# ElevenLabs Scribe v2 — primary STT provider for all supported languages.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=scribe_v2

# OpenAI (Whisper STT + translation fallback)
OPENAI_API_KEY=

# Groq Whisper fallback (used only when OpenAI fails or has no quota).
# Groq Whisper works well for English but degrades for other languages, so default is "en".
GROQ_API_KEY=
TILTAB_GROQ_WHISPER_LANGUAGES=en

# LLM cleanup provider: gemini | openai | groq | none
# Normalizes transcripts (Tajik dates/clitics/names, punctuation, code-switching, noise markers).
# Default chain: Gemini -> Groq -> OpenAI. Set to "none" to skip cleanup.
GEMINI_API_KEY=
TILTAB_CLEANUP_PROVIDER=
TILTAB_CLEANUP_MODEL=

# Daniel's Translation Module (to be wired in later)
TRANSLATION_MODULE_URL=

# Logging
LOG_LEVEL=info
DATABASE_URL=postgresql://tiltap:tiltap@localhost:5432/tiltap
