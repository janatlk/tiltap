# Server
PORT=3000
NODE_ENV=development

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Remote self-hosted STT service (e.g. Hetzner). Used for uz heavy local models.
# When the backend runs on the same server as the STT container, use http://localhost:8000
TILTAB_STT_SERVICE_URL=http://localhost:8000

# RunPod GPU STT endpoint (runsync URL). Optional; when set, ru/en/uz/tg/ky/auto/multi
# transcription is offloaded to a GPU worker.
TILTAB_GPU_STT_URL=
TILTAB_GPU_STT_API_KEY=
# Comma-separated list of language codes routed to the GPU worker.
TILTAB_GPU_STT_LANGUAGES=ru,en,uz,tg,ky,auto,multi
# How long the backend waits for a GPU STT job before giving up (milliseconds).
TILTAB_GPU_STT_TIMEOUT_MS=600000

# RunPod personal API key (Settings > API Keys). Only needed for
# scripts/update_runpod_gpu.py to force a new image pull after a GPU worker rebuild.
RUNPOD_PERSONAL_API_KEY=

# STT provider: elevenlabs | openai | local | auto
# - local: always use the local Python hybrid engine (default). GPU offloading
#   still applies when TILTAB_GPU_STT_URL is set; otherwise ru/en use local
#   Whisper large-v3-turbo and tg/uz/ky fall back to their local models.
# - elevenlabs: always use ElevenLabs Scribe v2
# - openai: always use OpenAI Whisper API
# - auto: cloud-first. ElevenLabs if ELEVENLABS_API_KEY is set, otherwise OpenAI/Groq, otherwise local engine
TILTAB_STT_PROVIDER=local

# ElevenLabs Scribe v2 — primary STT provider for all supported languages.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=scribe_v2

# Local multilingual Whisper model. Default is a CTranslate2 int8 conversion of
# openai/whisper-large-v3-turbo stored in models/whisper-large-v3-turbo-ct2.
# Set TILTAB_LOCAL_WHISPER_HF_MODEL to prefer a HuggingFace-format directory.
TILTAB_LOCAL_WHISPER_MODEL=models/whisper-large-v3-turbo-ct2
TILTAB_LOCAL_WHISPER_HF_MODEL=models/whisper-large-v3-turbo

# Whisper time-based chunking (only when VAD is disabled). Long audio is split
# into overlapping chunks so transcription does not drift on long podcasts.
TILTAB_WHISPER_CHUNK_THRESHOLD_SECONDS=300
TILTAB_WHISPER_CHUNK_SECONDS=300
TILTAB_WHISPER_CHUNK_OVERLAP_SECONDS=5

# OpenAI (Whisper STT + translation fallback)
OPENAI_API_KEY=

# Groq Whisper fallback (used only when OpenAI fails or has no quota).
# Groq Whisper works well for English but degrades for other languages, so default is "en".
GROQ_API_KEY=
TILTAB_GROQ_WHISPER_LANGUAGES=en

# LLM cleanup provider: openai | groq | gemini | none
# Normalizes transcripts (Tajik dates/clitics/names, punctuation, code-switching, noise markers).
# Default: openai (gpt-4o-mini). Set to "none" to skip cleanup.
TILTAB_CLEANUP_PROVIDER=openai
TILTAB_CLEANUP_MODEL=
TILTAB_CLEANUP_NON_TAJIK=1

# Free machine translation via Lingva (Google Translate front-end, no API key)
LINGVA_TRANSLATE_URL=https://lingva.ml
LINGVA_TRANSLATE_CHUNK_SIZE=2000

# Translation provider: lingva | openai | groq | azure | yandex | mock | auto
# - openai: LLM-based translation (default, uses gpt-4o-mini)
# - groq: LLM-based translation
# - lingva: free Lingva/Google Translate
# - azure: Microsoft Azure Translator (paid NMT, $10/M chars, 2M free/mo)
# - yandex: Yandex Cloud Translate (paid NMT, ~$4/M chars)
# - mock: returns placeholder text
# - auto: Lingva → Yandex → Azure → OpenAI/Groq → mock
TILTAB_TRANSLATION_PROVIDER=openai

# LLM translation safety limits. Lower max_tokens reduces runaway repetitive output,
# but may truncate very long translations. Review is skipped for combined inputs above
# the character threshold to avoid JSON-format failures on long texts.
TILTAB_TRANSLATION_MAX_TOKENS=4096
TILTAB_REVIEW_MAX_TOKENS=4096
TILTAB_REVIEW_MAX_INPUT_CHARS=3000

# Media downloads (YouTube, TikTok, Instagram) go through Cobalt only.
# yt-dlp was removed in July 2026: YouTube blocked it on the datacenter IP for
# essentially every request, so it never succeeded in production.
#
# Leave both empty to use the built-in rotation of public community instances
# (see DEFAULT_COBALT_APIS in youtube_cobalt.py). Public instances break often —
# for production load run your own and point COBALT_API_URL at it.
COBALT_API_URL=
COBALT_API_URLS=

# Cobalt health monitor. A background check periodically asks each configured
# Cobalt instance to resolve COBALT_HEALTHCHECK_URL. When they ALL fail, the bot
# sends a Telegram alert to TILTAB_ADMIN_CHAT_ID asking to add a working
# instance, and a recovery notice once one works again.
COBALT_HEALTHCHECK_ENABLED=true
COBALT_HEALTHCHECK_URL=https://www.youtube.com/watch?v=jNQXAC9IVRw
COBALT_HEALTHCHECK_INTERVAL_MINUTES=30
COBALT_ALERT_THROTTLE_HOURS=6

# Telegram chat ID that receives operational alerts (Cobalt down, etc.).
# This is the admin's own chat ID with the bot. Leave empty to disable alerts.
TILTAB_ADMIN_CHAT_ID=

# Daniel's Translation Module (to be wired in later)
TRANSLATION_MODULE_URL=

# Microsoft Azure Translator (optional paid fallback)
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=global
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# Yandex Cloud Translate (optional paid fallback, strong for Russian pairs)
YANDEX_TRANSLATE_API_KEY=
YANDEX_TRANSLATE_FOLDER_ID=
YANDEX_TRANSLATE_ENDPOINT=https://translate.api.cloud.yandex.net/translate/v2/translate

# Admin web UI token. If set, /web/admin.html API requires X-Admin-Token header.
# Leave empty for local development (open access).
TILTAB_ADMIN_TOKEN=

# Logging
LOG_LEVEL=info
DATABASE_URL=postgresql://tiltap:tiltap@localhost:5432/tiltap
