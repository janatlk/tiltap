# Server
PORT=3000
NODE_ENV=development

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# OpenAI (Whisper STT + GPT translation demo)
OPENAI_API_KEY=sk-your-openai-key

# STT provider: openai | local | auto
# - openai: always use OpenAI Whisper API
# - local: always use the local Python hybrid engine (requires models)
# - auto: use OpenAI Whisper API in production if OPENAI_API_KEY is set, otherwise local engine
TILTAB_STT_PROVIDER=auto

# Groq Whisper fallback (used only when OpenAI fails or has no quota).
# Groq Whisper works well for English but degrades for other languages, so default is "en".
GROQ_API_KEY=
TILTAB_GROQ_WHISPER_LANGUAGES=en

# ElevenLabs Scribe STT (optional; used as a high-quality provider for Tajik and other languages)
ELEVENLABS_API_KEY=

# Daniel's Translation Module (to be wired in later)
TRANSLATION_MODULE_URL=

# Logging
LOG_LEVEL=info
DATABASE_URL=postgresql://tiltap:tiltap@localhost:5432/tiltap
