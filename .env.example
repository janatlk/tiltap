# Server
PORT=3000
NODE_ENV=development

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Remote self-hosted STT service (e.g. Hetzner). Used for ky/uz heavy local models.
TILTAB_STT_SERVICE_URL=http://46.225.238.161:8000

# STT provider: elevenlabs | openai | local | auto
# - elevenlabs: always use ElevenLabs Scribe v2 (recommended)
# - openai: always use OpenAI Whisper API
# - local: always use the local Python hybrid engine (requires models; deprecated in cloud deployment)
# - auto: cloud-first. ElevenLabs if ELEVENLABS_API_KEY is set, otherwise OpenAI/Groq, otherwise local engine
TILTAB_STT_PROVIDER=auto

# ElevenLabs Scribe v2 — primary STT provider for all supported languages.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=scribe_v2

# OpenAI (Whisper STT + translation fallback)
OPENAI_API_KEY=

# Groq Whisper fallback (used only when OpenAI fails or has no quota).
# Groq Whisper works well for English but degrades for other languages, so default is "en".
GROQ_API_KEY=
TILTAB_GROQ_WHISPER_LANGUAGES=en

# LLM cleanup provider: gemini | openai | groq | none
# Normalizes transcripts (Tajik dates/clitics/names, punctuation, code-switching, noise markers).
# Default chain: Gemini -> Groq -> OpenAI. Set to "none" to skip cleanup.
GEMINI_API_KEY=
TILTAB_CLEANUP_PROVIDER=
TILTAB_CLEANUP_MODEL=

# Free machine translation via Lingva (Google Translate front-end, no API key)
LINGVA_TRANSLATE_URL=https://lingva.ml
LINGVA_TRANSLATE_CHUNK_SIZE=2000

# Translation provider: lingva | openai | groq | mock | auto
# - lingva: free Lingva/Google Translate
# - openai/groq: LLM-based translation
# - mock: returns placeholder text
# - auto: Lingva → OpenAI → Groq → mock
TILTAB_TRANSLATION_PROVIDER=auto

# YouTube anti-bot settings (optional). Needed when YouTube blocks datacenter IPs with
# "Sign in to confirm" or "HTTP Error 403".
# Export cookies from your browser as Netscape format and either:
#   - paste base64 content into YOUTUBE_COOKIES_BASE64
#   - mount the file and set YOUTUBE_COOKIES_PATH
YOUTUBE_COOKIES_BASE64=
YOUTUBE_COOKIES_PATH=
# PO token and visitor data for the YouTube web client (comma-separated CLIENT.CONTEXT+TOKEN).
# See: https://github.com/yt-dlp/yt-dlp/wiki/PO-Token-Guide
YOUTUBE_PO_TOKEN=
YOUTUBE_VISITOR_DATA=
# Set to true to update yt-dlp on every container start (recommended for Render).
YOUTUBE_AUTO_UPDATE_YTDLP=true

# Daniel's Translation Module (to be wired in later)
TRANSLATION_MODULE_URL=

# Logging
LOG_LEVEL=info
DATABASE_URL=postgresql://tiltap:tiltap@localhost:5432/tiltap
